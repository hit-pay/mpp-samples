# HitPay sandbox credentials — get from dashboard.sandbox.hit-pay.com → Developers → API Keys
HITPAY_API_KEY=test_...
HITPAY_WEBHOOK_SALT=...

# HitPay endpoints (sandbox defaults)
HITPAY_MPP_ENDPOINT=https://sandbox.mpp.hitpay.dev
HITPAY_API_BASE=https://api.sandbox.hit-pay.com

# Tempo testnet treasury wallet (signs the outbound USDC tx).
# HITPAY_TREASURY_PRIVATE_KEY takes precedence; TEMPO_PRIVATE_KEY is the fallback.
# Fund with TEMPO (gas) + test USDC at faucet.moderato.tempo.xyz
HITPAY_TREASURY_PRIVATE_KEY=0x...
# TEMPO_PRIVATE_KEY=0x...

# Local server port (default 4002)
PORT=4002

# FX rate USD → SGD (default 1.35)
BRIDGE_FX_USD_TO_SGD=1.35

# Polling fallback deadline in ms (default 5min). Polling runs in addition to
# the webhook handler — whichever sees `paid` first wins. Useful for dev when
# the tunnel/dashboard webhook isn't set up yet.
BRIDGE_POLL_FALLBACK_MS=300000
