# HitPay payouts API key — get from dashboard.sandbox.hit-pay.com → Developers → API Keys
# (sandbox payouts are gated; ask HitPay support for access if /v1/transfers returns 404)
HITPAY_PAYOUT_API_KEY=test_...
HITPAY_API_BASE=https://api.sandbox.hit-pay.com

# 1 = simulate transfers locally (no real /v1/transfers call); 0 = live sandbox transfers
HITPAY_PAYOUT_MOCK=1

# Stripe MPP — leave STRIPE_STUB=1 unless you have Stripe MPP / Tempo access
# (the stub demonstrates the cross-rail pattern without live USDC settlement)
STRIPE_STUB=1
# STRIPE_SECRET_KEY=sk_test_...      # only required when STRIPE_STUB=0
# TEMPO_PRIVATE_KEY=0x...            # only required when STRIPE_STUB=0; fund at faucet.moderato.tempo.xyz

# Beneficiary defaults — applied to every recipient unless overridden in PROVIDERS
SG_AGENT_BANK_HOLDER=AI SG Agent
SG_AGENT_BANK_SWIFT=DBSSSGSGXXX
SG_AGENT_BANK_ACCOUNT=1234567890

# Local server port (default 4002)
PORT=4002
